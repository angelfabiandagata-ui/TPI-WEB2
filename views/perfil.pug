extends layout.pug

block content
  .profile-container
    //- 1. Cabecera del Perfil
    header.profile-header
      .profile-avatar-container
        if userLogueado && usuario && userLogueado.id === usuario.id
          label.avatar-changer(for="file-avatar-input" style="cursor: pointer; position: relative; display: block;")
            if usuario.profile_photo 
              img#profile-avatar-img(src=usuario.profile_photo , alt="Foto de perfil", class="profile-avatar")
            else
              img#profile-avatar-img(src="/images/default-avatar.png", alt="Avatar por defecto", class="profile-avatar")
            
            .avatar-overlay Cambiar foto
          
          input#file-avatar-input(type="file" accept="image/*" style="display: none;")
        
        else
          if usuario && usuario.profile_photo
            img(src=usuario.avatar, alt="Foto de perfil", class="profile-avatar")
          else
            img(src="/images/default-avatar.png", alt="Avatar por defecto", class="profile-avatar")
      
      .profile-info
        .profile-title-row
          h2.profile-username #{usuario ? usuario.username : 'Usuario Invitado'}
          if userLogueado && usuario && userLogueado.id === usuario.id
            .profile-actions-group(style="display: flex; gap: 10px; align-items: center;")
              a.btn-logout(href="/auth/logout" style="color: #ff4d4d; font-weight: bold; text-decoration: none; border: 1px solid #ff4d4d; padding: 5px 10px; border-radius: 4px;") Cerrar Sesión
          else if userLogueado
            button.btn-follow Seguir
        
        .profile-stats
          span #[strong #{publicaciones ? publicaciones.length : 0}] publicaciones
          span #[strong #{seguidoresCount || 0}] seguidores
          span #[strong #{seguidosCount || 0}] seguidos

        .profile-bio
          p.profile-full-name #{usuario ? usuario.nombreCompleto : 'Nombre del Desarrollador'}
          p.profile-text #{usuario ? usuario.bio : '¡Bienvenido a mi perfil de Fotaza 2! Apasionado por la fotografía y el desarrollo web.'}

    hr.profile-divider

    //- 2. Grilla de Publicaciones
    section.profile-gallery
      if publicaciones && publicaciones.length > 0
        .gallery-grid
          each foto in publicaciones
            .gallery-item
              img(src=`/uploads/${foto.imagen}`, alt=foto.titulo)
              .gallery-item-overlay
                span.overlay-stat ❤️ #{foto.likes || 0}
                span.overlay-stat 💬 #{foto.comentarios || 0}
      else
        .gallery-empty
          p Cámara en mano, pero sin fotos todavía.
          if userLogueado && usuario && userLogueado.id === usuario.id
            a.btn-upload(href="/publicaciones/nueva") Subir mi primera foto

  script
    | const fileInput = document.querySelector('#file-avatar-input');
    | const avatarImg = document.querySelector('#profile-avatar-img');
    | if (fileInput) {
    |     fileInput.addEventListener('change', (e) => {
    |         const file = e.target.files[0];
    |         if (file) {
    |             const reader = new FileReader();
    |             reader.onloadend = async () => {
    |                 const base64String = reader.result;
    |                 try {
    |                     const response = await fetch('/perfil/cambiar-avatar', {
    |                         method: 'POST',
    |                         headers: { 'Content-Type': 'application/json' },
    |                         body: JSON.stringify({ avatar: base64String })
    |                     });
    |                     const data = await response.json();
    |                     if (data.success) {
    |                         avatarImg.src = base64String;
    |                         alert("¡Foto de perfil actualizada!");
    |                     } else {
    |                         alert("Hubo un error al guardar la foto.");
    |                     }
    |                 } catch (error) {
    |                     console.error("Error en la petición:", error);
    |                     alert("Error de conexión al actualizar la foto.");
    |                 }
    |             };
    |             reader.readAsDataURL(file);
    |         }
    |     });
    | }